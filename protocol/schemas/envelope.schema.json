{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unity-editor-mcp/protocol/schemas/envelope.schema.json",
  "title": "Unity Editor MCP — Wire Envelope",
  "description": "Request/response envelope carried over the length-prefixed TCP frame (4-byte big-endian length + UTF-8 JSON). As of v0.4.0 the editor serves this via the tested Core HandlerOutcome/CommandResult rail, which cannot serialize a handler-level error as success. Not yet machine-enforced via conformance vectors.",
  "oneOf": [
    { "$ref": "#/$defs/request" },
    { "$ref": "#/$defs/successResponse" },
    { "$ref": "#/$defs/errorResponse" }
  ],
  "$defs": {
    "request": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Client-assigned correlation id." },
        "type": { "type": "string", "description": "Command type from the catalog." },
        "params": { "type": "object", "description": "Command parameters (validated against the catalog params schema). Also accepts a reserved \"fields\" (string[] of dot-paths) selecting which result fields to return, GraphQL-style — see protocol/README.md → Result field selection." }
      }
    },
    "successResponse": {
      "type": "object",
      "required": ["id", "status", "result"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "status": { "const": "success" },
        "result": { "description": "Result payload (catalog result schema)." },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "errorResponse": {
      "type": "object",
      "required": ["id", "status", "error", "code"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "status": { "const": "error" },
        "error": { "type": "string", "description": "Human-readable message." },
        "code": { "type": "string", "description": "Machine error code (see error-codes.json)." },
        "remediation": { "type": "string", "description": "What the caller should do next." },
        "details": { "type": "object" }
      }
    }
  }
}
